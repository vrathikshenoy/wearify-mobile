{
  "expo": {
    "name": "Wearify",
    "slug": "vrathik",
    "version": "1.0.0",
    "scheme": "wearify",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.phygify.wearify",
      "associatedDomains": [
        "applinks:wearify-app.vercel.app"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.phygify.wearify",
      "blockedPermissions": [
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#68262A",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "wearify-app.vercel.app",
              "pathPrefix": "/c"
            },
            {
              "scheme": "https",
              "host": "wearify-app.vercel.app",
              "pathPrefix": "/register"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ],
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Wearify to select your profile photo.",
          "cameraPermission": "Allow Wearify to take your profile photo.",
          "microphonePermission": false
        }
      ],
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-logo.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#68262A"
        }
      ],
      "expo-font",
      "expo-video",
      "expo-notifications",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/285c421c-18da-4746-ae3d-9170c2d23006"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "285c421c-18da-4746-ae3d-9170c2d23006"
      }
    },
    "owner": "vrathiks-team"
  }
}
